[node name="Separador4" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="Pausa" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.55, 0.2, 1)
theme_override_font_sizes/font_size = 20
text = "ESC - Pausar"
horizontal_alignment = 1

[node name="BotonRegresar" type="Button" parent="VBoxContainer"]
custom_minimum_size = Vector2(200, 60)
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 0.7, 0.25, 1)
theme_override_font_sizes/font_size = 26
theme_override_styles/normal = SubResource("StyleBoxFlat_normal")
theme_override_styles/pressed = SubResource("StyleBoxFlat_pressed")
theme_override_styles/hover = SubResource("StyleBoxFlat_hover")
text = "REGRESAR"

[connection signal="pressed" from="VBoxContainer/BotonRegresar" to="." method="_on_boton_regresar_pressed"]
