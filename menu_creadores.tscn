[gd_scene format=3 uid="uid://creadores_menu"]

[ext_resource type="Script" path="res://menu_creadores.gd" id="1_script"]

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_normal"]
bg_color = Color(0.05, 0.05, 0.05, 0)

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_hover"]
bg_color = Color(0.6, 0.4, 0.1, 0.15)
border_color = Color(0.8, 0.6, 0.2, 0.8)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_pressed"]
bg_color = Color(0.8, 0.6, 0.2, 0.2)

[node name="MenuCreadores" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="FondoOscuro" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.03, 0.03, 0.05, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 0
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -350.0
offset_top = -300.0
offset_right = 350.0
offset_bottom = 300.0
grow_horizontal = 2
grow_vertical = 2
alignment = 1
theme_override_constants/separation = 30

[node name="Titulo" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.75, 0.3, 1)
theme_override_font_sizes/font_size = 52
text = "CREADORES"
horizontal_alignment = 1

[node name="Separador1" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="Subtitulo" type="Label" parent="VBoxContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.55, 0.2, 1)
theme_override_font_sizes/font_size = 26
text = "HEREDERO DE LA CENIZA"
horizontal_alignment = 1

[node name="Separador2" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="CreadoresContainer" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 35

[node name="Creador1" type="VBoxContainer" parent="VBoxContainer/CreadoresContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 5

[node name="Nombre1" type="Label" parent="VBoxContainer/CreadoresContainer/Creador1"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.8, 0.5, 1)
theme_override_font_sizes/font_size = 32
text = "EMILIANO ALVARADO CHAVEZ"
horizontal_alignment = 1

[node name="Rol1" type="Label" parent="VBoxContainer/CreadoresContainer/Creador1"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.5, 0.3, 1)
theme_override_font_sizes/font_size = 20
text = "Desarrollador"
horizontal_alignment = 1

[node name="Creador2" type="VBoxContainer" parent="VBoxContainer/CreadoresContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 5

[node name="Nombre2" type="Label" parent="VBoxContainer/CreadoresContainer/Creador2"]
layout_mode = 2
theme_override_colors/font_color = Color(0.9, 0.8, 0.5, 1)
theme_override_font_sizes/font_size = 32
